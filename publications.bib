@article{siekierka-kleiserQuantitativeAssessmentRecovery2006,
  title = {Quantitative Assessment of Recovery from Motor Hemineglect in Acute Stroke Patients},
  author = {{Siekierka-Kleiser}, E. M. and Kleiser, R. and Wohlschl{\"a}ger, A. M. and Freund, H. J. and Seitz, R. J.},
  year = {2006},
  journal = {Cerebrovascular Diseases},
  volume = {21},
