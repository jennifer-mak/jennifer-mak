@article{kamaliTracingSuperiorLongitudinal2014,
  title = {Tracing Superior Longitudinal Fasciculus Connectivity in the Human Brain Using High Resolution Diffusion Tensor Tractography},
  author = {Kamali, Arash and Flanders, Adam E. and Brody, Joshua and Hunter, Jill V. and Hasan, Khader M.},
  year = {2014},
