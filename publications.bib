@article{Kim2021FOPRTest,
  title = {{{FOPR}} Test: A Virtual Reality-Based Technique to Assess Field of Perception and Field of Regard in Hemispatial Neglect},
  author = {Kim, Tae Lim and Kim, Kwanguk and Choi, Changyeol and Lee, Ji Yeong and Shin, Joon Ho},
  year = {2021},
  month = dec,
  journal = {Journal of NeuroEngineering and Rehabilitation},
  volume = {18},
  number = {1},
  publisher = {{BioMed Central Ltd}},
  issn = {17430003},
  doi = {10.1186/s12984-021-00835-1},
  abstract = {Background: We previously proposed a novel virtual reality-based method to assess human field of perception (FOP) and field of regard (FOR), termed the FOPR test. This study assessed the diagnostic validity of the FOPR test for hemispatial neglect (HSN). Methods: We included 19 stroke patients with a lesion in the right hemisphere and with HSN (HSN+SS), 22 stroke patients with a lesion in the right hemisphere and without HSN (HSN-SS), and 22 healthy controls aged 19\textendash 65~years. The success rate (SR) and response time (RT) in the FOPR test for both FOP and FOR were assessed (FOP-SR, FOR-SR, FOP-RT, and FOR-RT, respectively). Using a Bland\textendash Altman plot, agreements between the FOPR test and conventional tests were confirmed, and the FOPR test accuracy was verified using the support vector machine (SVM). Measured values were analysed using ANOVA and Kruskall\textendash Wallis tests for group comparison. Results: The Bland\textendash Altman plot showed good agreement between FOPR test and conventional tests; individuals within 95\% agreement limits were within the range of 94.8\textendash 100.0\%. The SVM classification accuracy, using FOP and FOR variables from the left hemispace, ranged from 83.3 to 100.0\% in a binary classification (HSN vs non-HSN). The FOPR test demonstrated differences in SR and RT for both FOP and FOR across the groups. Conclusion: The FOPR test was valid for the HSN diagnosis and provided quantitative and intuitive information regarding visuospatial function. Furthermore, it might enhance our understanding of visuospatial function including HSN by applying the time relative component and concepts of perception and exploration, FOP and FOR. Trial registration: NCT03463122. Registered 13 March 2018, retrospectively registered.},
  pmid = {33602254},
  keywords = {Field of perception,Field of regard,Hemispheric stroke,Rehabilitation,Virtual reality,Visuospatial function},
  file = {C\:\\Users\\Jennifer Mak\\Zotero\\storage\\JHVR8IDD\\FOPR test a virtual reality-based technique to assess field of perception and field of regard in hemispatial neglect.pdf}
}

@article{Kimura2018DifferencesNeglect,
