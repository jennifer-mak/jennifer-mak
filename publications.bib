  issn = {18632653},
  doi = {10.1007/s00429-012-0498-y},
  abstract = {The major language pathways such as superior longitudinal fasciculus (SLF) pathways have been outlined by experimental and diffusion tensor imaging (DTI) studies. The SLF I and some of the superior parietal lobule connections of the SLF pathways have not been depicted by prior DTI studies due to the lack of imaging sensitivity and adequate spatial resolution. In the current study, the trajectory of the SLF fibers has been delineated on five healthy human subjects using diffusion tensor tractography on a 3.0-T scanner at high spatial resolution. We also demonstrate for the first time the trajectory and connectivity of the SLF fibers in relation to other language pathways as well as the superior parietal lobule connections of the language circuit using high spatial resolution DTI in the healthy adult human brain. \textcopyright{} 2012 Springer-Verlag Berlin Heidelberg.},
