@article{albertSimpleTestVisual1973,
  title = {A Simple Test of Visual Neglect},
  author = {Albert, Martin L.},
  year = {1973},
  journal = {Neurology},
  volume = {23},
  number = {6},
  pages = {658--664},
  issn = {1526632X},
  doi = {10.1212/wnl.23.6.658},
  abstract = {A simple, clinically useful test for visual neglect was administered to 96 subjects: 66 had unilateral, circumscribed, surgically verified, cerebral hemispheric lesions (36 LBD and 30 RBD); thirty were non-brain-damaged controls. Forty 2.5 cm lines were drawn in the presence of the subject in an apparently random manner on an unlined sheet of paper placed before the subject. The actual disposition of these lines was standardized, allowing for a systematic analysis of subjects' performance on the left, the right, and the center of the page. The subject was instructed to draw a line through all the lines. Scoring was based on the number and location of lines left uncrossed. Major results were as follows: (1) Visual neglect occurred in 30 percent of subjects with LBD and in 37 percent of those with RBD. (2) The severity of the neglect, but not the frequency, was significantly greater after RBD than LBD. (3) Visual neglect occurred in the center of the page or on both sides of the page more often than on only the side contralateral to the lesion. Visual neglect thus appears to be more a bilateral than a unilateral phenomenon. (4) Visual neglect may occur without a visual field defect, and a visual field defect may occur without visual neglect. This study supports the theoretical position that visual neglect is not a single process but rather is a manifestation of several different types of neurologic dysfunction. \textcopyright{} 1973 American Academy of Neurology.},
  pmid = {4736313},
  file = {C\:\\Users\\Jennifer Mak\\Zotero\\storage\\M4RXM38N\\A simple test of visual neglect.pdf}
}

