@article{tungOptogeneticApproachesControlling2016,
 abstract = {Optogenetics, a technique that utilizes light-sensitive ion channels or pumps to activate or inhibit neurons, has allowed scientists unprecedented precision and control for manipulating neuronal activity. With the clinical need to develop more precise and effective therapies for patients with drug-resistant epilepsy, these tools have recently been explored as a novel treatment for halting seizure activity in various animal models. In this review, we provide a detailed and current summary of these optogenetic approaches and provide a perspective on their future clinical application as a potential neuromodulatory therapy.},
 author = {Tung, Jack K. and Berglund, Ken and Gross, Robert E.},
 doi = {10.1016/j.brs.2016.06.055},
 file = {C\:\\Users\\Jennifer Mak\\Zotero\\storage\\5GRJXSWG\\tung.pdf},
 issn = {18764754},
 journal = {Brain Stimulation},
 keywords = {Epilepsy,Neuromodulation,Optogenetics},
 month = {November},
 number = {6},
 pages = {801--810},
 pmid = {27496002},
 publisher = {Elsevier Inc.},
 title = {Optogenetic Approaches for Controlling Seizure Activity},
 volume = {9},
 year = {2016}
}
