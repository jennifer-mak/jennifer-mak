@article{staggNeurochemicalEffectsTheta2009,
 abstract = {Continuous theta burst stimulation (cTBS) is a novel transcranial stimulation technique that causes significant inhibition of synaptic transmission for $łeq$1 h when applied over the primary motor cortex (M1) in humans. Here we use magnetic resonance spectroscopy to define mechanisms mediating this inhibition by noninvasively measuring local changes in the cortical concentrations of $γ$-aminobutyric acid (GABA) and glutamate/glutamine (Glx). cTBS to the left M1 led to an increase in GABA compared with stimulation at a control site without significant change in Glx. This direct evidence for increased GABAergic interneuronal activity is framed in terms of a new hypothesis regarding mechanisms underlying cTBS. Copyright © 2009 The American Physiological Society.},
 author = {Stagg, C. J. and Wylezinska, M. and Matthews, P. M. and Johansen-Berg, H. and Jezzard, P. and Rothwell, J. C. and Bestmann, S.},
 doi = {10.1152/jn.91060.2008},
 file = {C\:\\Users\\Jennifer Mak\\Zotero\\storage\\M7KIUMXG\\Neurochemical Effects of Theta Burst Stimulation as Assessed by Magnetic.pdf},
 issn = {00223077},
 journal = {Journal of Neurophysiology},
 number = {6},
 pages = {2872--2877},
 title = {Neurochemical Effects of Theta Burst Stimulation as Assessed by Magnetic Resonance Spectroscopy},
 volume = {101},
 year = {2009}
}
