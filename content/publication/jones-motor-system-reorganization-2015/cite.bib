 author = {Jones, Theresa A. and Adkins, DeAnna L.},
 doi = {10.1152/physiol.00014.2015},
 isbn = {1548-9221},
 issn = {1548-9213},
 journal = {Physiology},
 pmid = {26328881},
 title = {Motor System Reorganization After Stroke: Stimulating and Training Toward Perfection},
 year = {2015}
}
