@inproceedings{Ferraro2021AssessmentUnilateral,
 abstract = {Among the several disabling features following a stroke, the unilateral spatial neglect (USN) is one of the most frequently present in case of right-sided lesions. The standard assessment of such a pathology happens via tests that are usually performed on paper. However, a great interest toward digital solutions for USN is arising, in order to facilitate the activities of medical specialists. Furthermore, the recent outbreak of COVID-19 is stressing the importance of remote assistive tools which enable the continuity of care at patient's home. Indeed, connected technology allows for remote monitoring of patients by the clinical staff, hence enabling the definition of a personalized plan of care even after the de-hospitalization and in safe conditions. In addition, USN patients are among the so-called fragile subjects who, due to their condition, require continuous monitoring and rehabilitative therapeutic intervention, which can be granted by some ICT solution. The present work introduces the battery of tests for the assessment of USN which are included in the ReMoVES system. They are digital versions of standard tests that can be practiced via a touchscreen. The informative content that such activities deliver is wider and more comprehensive than the paper based versions. The experimental phase is described with respect to the well-known Albert's test, in a real-life scenario. The indicators that can be computed are here defined and described.},
 author = {Ferraro, Federica and Trombini, Marco and Truffelli, Romina and Simonini, Marina and Dellepiane, Silvana},
 booktitle = {International IEEE/EMBS Conference on Neural Engineering, NER},
 doi = {10.1109/NER49283.2021.9441471},
 file = {C\:\\Users\\Jennifer Mak\\Zotero\\storage\\X2HAAL8N\Øn the Assessment of Unilateral Spatial Neglect via Digital Tests.pdf},
 isbn = {978-1-72814-337-8},
 issn = {19483554},
 keywords = {Cognitive assessment,Digital solution,Unilateral spatial neglect},
 month = {May},
 pages = {802--806},
 publisher = {IEEE Computer Society},
 title = {On the Assessment of Unilateral Spatial Neglect via Digital Tests},
 volume = {2021-May},
 year = {2021}
}
