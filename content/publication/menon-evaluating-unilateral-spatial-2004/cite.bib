@article{menonEvaluatingUnilateralSpatial2004,
 abstract = {This study identified, using a comprehensive review of the literature, 62 standardized and nonstandardized assessment tools that exist to evaluate unilateral spatial neglect (USN). Each standardized tool was critically appraised according to its purpose (hemispace assessed), psychometric properties, and client appropriateness. The findings on the 28 standardized tools were compiled into a USN Assessment Summary Guide to facilitate clinical decision-making regarding the standardized USN assessments that are appropriate for specific clients at different phases of their recovery post stroke.},
 author = {Menon, Anita and Korner-Bitensky, Nicol},
 doi = {10.1310/KQWL-3HQL-4KNM-5F4U},
 file = {C\:\\Users\\Jennifer Mak\\Zotero\\storage\\QPF4LI9Y\\Evaluating unilateral spatial neglect post stroke working your way through the maze of assessment choices.pdf},
 issn = {10749357},
 journal = {Topics in Stroke Rehabilitation},
 keywords = {Assessment tools,Evaluation,Inattention,Psychometric properties,Reliability,Stroke,Unilateral spatial neglect,Validity,Visual neglect,Visual perception},
 number = {3},
 pages = {41--66},
 pmid = {15480953},
 title = {Evaluating Unilateral Spatial Neglect Post Stroke: Working Your Way through the Maze of Assessment Choices},
 volume = {11},
 year = {2004}
}
