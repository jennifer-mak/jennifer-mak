@article{corbettaReorientingSystemHuman2008,
 abstract = {Survival can depend on the ability to change a current course of action to respond to potentially advantageous or threatening stimuli. This "reorienting" response involves the coordinated action of a right hemisphere dominant ventral frontoparietal network that interrupts and resets ongoing activity and a dorsal frontoparietal network specialized for selecting and linking stimuli and responses. At rest, each network is distinct and internally correlated, but when attention is focused, the ventral network is suppressed to prevent reorienting to distracting events. These different patterns of recruitment may reflect inputs to the ventral attention network from the locus coeruleus/norepinephrine system. While originally conceptualized as a system for redirecting attention from one object to another, recent evidence suggests a more general role in switching between networks, which may explain recent evidence of its involvement in functions such as social cognition. © 2008 Elsevier Inc. All rights reserved.},
 author = {Corbetta, Maurizio and Patel, Gaurav and Shulman, Gordon L.},
 doi = {10.1016/j.neuron.2008.04.017},
 file = {C\:\\Users\\Jennifer Mak\\Zotero\\storage\\V7RK4PQQ\\1-s2.0-S0896627308003693-main.pdf},
 issn = {08966273},
 journal = {Neuron},
 number = {3},
 pages = {306--324},
 pmid = {18466742},
 title = {The Reorienting System of the Human Brain: From Environment to Theory of Mind},
 volume = {58},
 year = {2008}
}
