@article{gauthierBellsTestQuantitative1989,
 abstract = {The Bells Test, a cancellation task, permits a quantitative and qualitative evaluation of visual neglect. The construction of the test allows for rapid visualization of the spatial distribution of the omitted targets and their quantification. The examiner can also obtain a qualitative picture through an approximation of the visual scanning pattern used by the subject: this provides valuable information on "how" the task is performed. In summary, the Bells Test is a more dynamic, and thus, more sensitive clinical examination for visual neglect.},
 author = {Gauthier, Louise and Dehau Lab Th-Alajouanine, Francois T and Yves Joanette, Montreal},
 file = {C\:\\Users\\Jennifer Mak\\Zotero\\storage\\CQNXNHMX\\The Bells Test A Quantitative and Qualitative Test For Visual Neglect.pdf},
 journal = {International Journal of Clinical Neuropsychology},
 number = {2},
 pages = {49--54},
 title = {The Bells Test: A Quantitative and Qualitative Test For Visual Neglect},
 volume = {11},
 year = {1989}
}
