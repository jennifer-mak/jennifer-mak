@article{jehkonenVisualNeglectPredictor2000,
 abstract = {Objectives$±$ The aim was to study the role of visual neglect in acute righthemisphere brain infarct as a predictor of poor functional outcomeduring the Æ rst year after stroke. In particular, we were interested in theadditional value of neglect measures besides hemiparesis, hemianopia,cognitive deÆ cits and age.Patients and methods$±$ A consecutive series of57 patients with a neuroradiologically veriÆ ed right hemisphere infarctwas examined within 10 days of the stroke. Fifty patients were followedup for 1 year. Neglect was measured with the Conventional and theBehavioural subtests of the Behavioural Inattention Test (BITC andBITB, respectively). The predictors were determined at the 10-dayexamination. Functional outcome was assessed 3, 6 and 12 months afterthe onset with the Frenchay Activities Index.Results$±$ Neglect in BITBwas the best single predictor, which together with high age formed thebest combination of predictors for poor functional outcome at eachfollow-up. Hemiparesis was also included in this prediction model at the3-month follow-up, but hemianopia, BITC, or visuoconstructional andmemory deÆ cits showed no additional predictive value. However, neglectusually recovered soon. When neurological and cognitive deÆ cits wereassessed at the same time as the outcome, hemiparesis rather than neglectwas the strongest correlate of poor outcome.Conclusion$±$ Neglect inacute stroke is an important predictor of poor functional recovery.Residual neglect, which could be compensated in the follow-up tests,may nevertheless restrict patients' real-life activities and hobbies},
 author = {Jehkonen, M. and Ahonen, J-P. and Dastidar P. and Koivisto, A-M. and Laippala, P. and Vilkki, J. and Molnár, G.},
 file = {C\:\\Users\\Jennifer Mak\\Zotero\\storage\\W76TYZSQ\\Visual neglect as a predictor of functional outcome one year after stroke.pdf},
 journal = {Acta Neurologica Scandinavia},
 pages = {195--201},
 title = {Visual Neglect as a Predictor of Functional Outcome One Year after Stroke},
 volume = {101},
 year = {2000}
}
