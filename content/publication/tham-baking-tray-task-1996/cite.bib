@article{thamBakingTrayTask1996,
 abstract = {This paper describes a new neglect test, where patients are asked to spread out 16 cubes as evenly as possible over a 75 x 100 cm board 'as if they were buns on a baking tray'. A consecutive series of 52 brain-damaged patients and 30 control subjects were examined with the new test as well as with several commonly used neglect tests. The baking tray task proved to be a quick and yet sensitive test, suitable for screening purposes and longitudinal studies.},
 author = {Tham, Kerstin and Tegnér, Richard},
 doi = {10.1080/713755496},
 file = {C\:\\Users\\Jennifer Mak\\Zotero\\storage\\RNFM46Q7\\The baking tray task a test of spatial neglect.pdf},
 issn = {09602011},
 journal = {Neuropsychological Rehabilitation},
 number = {1},
 pages = {19--26},
 title = {The Baking Tray Task: A Test of Spatial Neglect},
 volume = {6},
 year = {1996}
}
